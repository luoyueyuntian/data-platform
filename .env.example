# ============================================================
# SSAS Platform - Environment Configuration
# Copy this file to .env and adjust values
# ============================================================

# ---- Database (single instance: PostgreSQL + TimescaleDB extension) ----
DATABASE_URL="postgresql://ssas:ssas@localhost:5432/ssas"

# ---- Redis ----
REDIS_URL="redis://localhost:6379/0"

# ---- Kafka ----
KAFKA_BROKER="localhost:9092"
KAFKA_CLIENT_ID="ssas-platform"

# ---- MQTT ----
MQTT_BROKER_URL="mqtt://localhost:1883"
# MQTT_BROKER_URL="mqtts://localhost:8883"  # TLS
MQTT_USERNAME="ssas"
MQTT_PASSWORD="ssas"

# ---- Auth ----
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- API ----
API_PORT=4000
API_HOST="0.0.0.0"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# ---- Worker ----
WORKER_CONCURRENCY=5
DATA_RETENTION_DAYS=730  # 2 years
