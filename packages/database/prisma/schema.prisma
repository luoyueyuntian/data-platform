// ============================================================
// SSAS Platform - Prisma Schema
// Database: PostgreSQL + TimescaleDB
// Generic Data Analytics Platform
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  schemas   = ["public", "timescale"]
}

// ============================================================
// Tenant / Multi-tenancy
// ============================================================

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  plan      String   @default("free") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entities     Entity[]
  users        User[]
  alertRules   AlertRule[]
  dashboards   Dashboard[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  entityGroups EntityGroup[]

  @@schema("public")
  @@map("tenants")
}

// ============================================================
// User / Authentication
// ============================================================

model User {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  email      String    @unique @db.VarChar(255)
  name       String    @db.VarChar(255)
  password   String?   @db.VarChar(255) // hashed, nullable for OAuth
  role       String    @default("viewer") @db.VarChar(50) // admin | operator | analyst | viewer | custom
  status     String    @default("active") @db.VarChar(20) // active | disabled | invited
  lastLoginAt DateTime? @map("last_login_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@schema("public")
  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(255)
  key        String    @unique @db.VarChar(255) // hashed key
  permissions String[] @default([]) // JSON list of permission strings
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@schema("public")
  @@map("api_keys")
}

// ============================================================
// Entity / Group / Tag
// ============================================================

model EntityGroup {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   EntityGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id])
  children EntityGroup[] @relation("GroupHierarchy")
  entities Entity[]

  @@unique([tenantId, name])
  @@schema("public")
  @@map("entity_groups")
}

model Entity {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  entityKey   String   @unique @db.VarChar(255) // unique identifier (serial number, user ID, etc.)
  type        String   @default("custom") @db.VarChar(50)
  status      String   @default("inactive") @db.VarChar(20) // active | inactive | error | disabled | maintenance
  groupId     String?  @map("group_id") @db.Uuid
  location    Json?    // EntityLocation: { name, lat, lng, address }
  metadata    Json?    // arbitrary custom fields
  phase       String   @default("registered") @db.VarChar(50) // lifecycle: registered | active | running | maintenance | retired
  lastSeenAt  DateTime? @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group    EntityGroup? @relation(fields: [groupId], references: [id])
  tags     EntityTag[]

  @@index([tenantId])
  @@index([status])
  @@index([groupId])
  @@index([entityKey])
  @@schema("public")
  @@map("entities")
}

model EntityTag {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  key       String   @db.VarChar(128)
  value     String   @db.VarChar(255)
  source    String   @default("manual") @db.VarChar(50) // manual | rule | import | computed
  createdAt DateTime @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([key, value])
  @@schema("public")
  @@map("entity_tags")
}

// ============================================================
// Alert Rules & Records
// ============================================================

model AlertRule {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  conditions     Json     // AlertCondition[]: [{ eventName, operator, threshold, duration, window }]
  conditionLogic String   @default("all") @db.VarChar(10) // all | any
  channels       Json     // AlertChannel[]: [{ type: "webhook"|"email", config: {...} }]
  silenceSeconds Int      @default(300) @map("silence_seconds")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  records AlertRecord[]

  @@index([tenantId])
  @@schema("public")
  @@map("alert_rules")
}

model AlertRecord {
  id             String    @id @default(uuid()) @db.Uuid
  ruleId         String    @map("rule_id") @db.Uuid
  ruleName       String    @db.VarChar(255)
  entityId       String?   @map("entity_id") @db.Uuid
  triggeredValue Float     @map("triggered_value")
  severity       String    @default("warn") @db.VarChar(20) // info | warn | critical
  message        String    @db.Text
  status         String    @default("firing") @db.VarChar(20) // firing | resolved | acknowledged | silenced
  triggeredAt    DateTime  @map("triggered_at")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedBy     String?   @map("resolved_by") @db.VarChar(255)

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([entityId])
  @@index([status])
  @@index([triggeredAt])
  @@schema("public")
  @@map("alert_records")
}

// ============================================================
// Dashboard & Panels
// ============================================================

model Dashboard {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  layout      Json?    // DashboardLayout: { columns, rowHeight }
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  panels Panel[]

  @@index([tenantId])
  @@schema("public")
  @@map("dashboards")
}

model Panel {
  id          String @id @default(uuid()) @db.Uuid
  dashboardId String @map("dashboard_id") @db.Uuid
  title       String @db.VarChar(255)
  type        String @default("line") @db.VarChar(50) // line | bar | pie | gauge | table | heatmap | scatter | stat | area
  query       Json   // PanelQuery: { eventNames, aggregation, granularity, filters, timeRange }
  position    Json   // { x, y, w, h }
  style       Json?  // custom style overrides

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@schema("public")
  @@map("panels")
}

// ============================================================
// Time-Series Events (TimescaleDB Hypertable)
// Note: This model is defined for Prisma Client type generation.
// The actual table is managed as a TimescaleDB hypertable via raw SQL.
// ============================================================

/// Generic event data point. Stored in TimescaleDB hypertable.
model Event {
  time       DateTime @map("time")
  entityId   String   @map("entity_id") @db.Uuid
  eventName  String   @map("event_name") @db.VarChar(100)
  value      Float?
  properties Json?    // Record<string, unknown>
  tags       Json?    // Record<string, string>
  quality    Int      @default(100) // 0-100

  @@id([time, entityId, eventName])
  @@index([entityId, eventName, time])
  @@index([entityId, time])
  @@schema("timescale")
  @@map("events")
}

// ============================================================
// Audit Log
// ============================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100) // e.g. "entity.create", "alert.update"
  resource   String   @db.VarChar(100) // e.g. "entity", "alert_rule"
  resourceId String?  @map("resource_id") @db.VarChar(255)
  detail     Json?    // arbitrary event details
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([resource, resourceId])
  @@schema("public")
  @@map("audit_logs")
}
